#!/bin/bash
# psm_shutdown - PiStorms-aware shutdown/halt script

usage() {
    echo "Usage: psm_shutdown [options] [time] [wall]"
    echo "Options and parameters are same as 'shutdown' command"
    exit -1
}

# Determine command name
cmd=$(basename "$0")

# Infer first argument based on command name
if [ "$cmd" == "poweroff" ]; then
    arg1="-P"
else
    # If called directly as psm_shutdown, take first argument
    if [ $# -eq 0 ]; then
        usage
    fi
    arg1=$1
fi

# Only call PiStorms shutdown if halting or powering off
if [[ "$arg1" == "-H" || "$arg1" == "-h" || "$arg1" == "--halt" || "$arg1" == "-P" || "$arg1" == "--poweroff" ]]; then
    echo "halting PiStorms..."
    python3 - <<EOF
import sys
sys.path.append("/home/robot/Projects/PiStorms/sys")
from PiStorms import PiStorms

psm = PiStorms()
psm.Shutdown()
EOF
fi

# Call the real shutdown command with all arguments
/sbin/shutdown "$@"